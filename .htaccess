RewriteEngine On
RewriteBase /recipesManager/

# -----------------------------------------------------------------
# Security Rules
# -----------------------------------------------------------------

# Block direct access to app folder except assets
RewriteCond %{REQUEST_URI} ^/recipesManager/app/ [NC]
RewriteCond %{REQUEST_URI} !\.(css|js|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf)$ [NC]
RewriteRule ^ - [F,L]

# Block access to hidden dotfiles (.env, .git, .htaccess etc)
RewriteRule (^\.|/\.) - [F,L]

# -----------------------------------------------------------------
# Router
# -----------------------------------------------------------------

# Serve existing files directly
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Route everything else to router/index.php
RewriteRule ^(.*)$ index.php?url=$1 [QSA,L]
