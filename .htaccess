RewriteEngine On
RewriteBase /recipesManager/

# -----------------------------------------------------------------
# Security Rules
# -----------------------------------------------------------------

# Block direct access to app folder
RewriteCond %{REQUEST_URI} ^/recipesManager/app/ [NC]
RewriteRule ^ - [F,L]

# Allow access to public folder
RewriteCond %{REQUEST_URI} ^/recipesManager/public/ [NC]
RewriteRule ^ - [L]

# Block access to hidden dotfiles (.env, .git, .htaccess etc)
RewriteRule (^\.|/\.) - [F,L]

# -----------------------------------------------------------------
# Router
# -----------------------------------------------------------------

# Serve existing files directly
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Route everything else to index.php
RewriteRule ^(.*)$ index.php?url=$1 [QSA,L]
